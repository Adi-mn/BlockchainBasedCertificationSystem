{
  "name": "certificate-verification-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for blockchain certificate verification system",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy": "npx hardhat run scripts/deploy.js",
    "deploy:polygon": "npx hardhat run scripts/deploy.js --network polygon",
    "deploy:mumbai": "npx hardhat run scripts/deploy.js --network mumbai",
    "verify": "npx hardhat verify --network polygon",
    "node": "npx hardhat node",
    "clean": "npx hardhat clean"
  },
  "keywords": ["blockchain", "certificates", "verification", "solidity", "hardhat"],
  "author": "Certificate Verification Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.1",
    "@nomiclabs/hardhat-etherscan": "^3.1.2",
    "hardhat": "^2.12.2",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.8.0",
    "dotenv": "^16.0.3"
  }
}